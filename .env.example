# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL — get connection string from https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/hostello?sslmode=require"

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — leave blank to disable Google sign-in)
# Console: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# Dashboard: https://dash.cloudflare.com → R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="hostello-uploads"
# CRITICAL in production: used for image URL allowlisting and security validation.
# Missing this in production causes image updates to fail with unclear error messages.
R2_PUBLIC_URL=""

# ── Upstash Redis ─────────────────────────────────────────────────────────────
# Used for: rate limiting, token-version caching, QStash webhook verification
# Console: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Payment Gateways ──────────────────────────────────────────────────────────

# Safepay (card payments — enabled by default)
# Dashboard: https://getsafepay.com/dashboard
SAFEPAY_SECRET=""
SAFEPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_SAFEPAY_ENV="sandbox"   # "sandbox" | "production"

# JazzCash (mobile wallet — disabled in payment-methods.ts, enable when ready)
# Dashboard: https://sandbox.jazzcash.com.pk/MerchantPortal
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
JAZZCASH_ENV="sandbox"              # "sandbox" | "production"

# EasyPaisa (mobile wallet — disabled in payment-methods.ts, enable when ready)
# Dashboard: https://easypaisasandbox.pk/MerchantPortal
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""               # 16-character AES key from the portal
EASYPAISA_ENV="sandbox"             # "sandbox" | "production"

# Payment gateway IP allowlisting (optional — signatures alone are sufficient)
# Adds defense-in-depth by blocking callbacks from unexpected IP addresses.
# Format: "gateway1:ip1,ip2;gateway2:ip3"
# Example: GATEWAY_IPS="jazzcash:203.0.113.1,203.0.113.2;easypaisa:192.0.2.1"
# Leave empty to disable (recommended until you have confirmed gateway IPs).
GATEWAY_IPS=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
# Without a real key, emails are logged to console in development.
RESEND_API_KEY=""
EMAIL_FROM="HostelLo <noreply@hostello.pk>"
SUPPORT_EMAIL="support@hostello.pk"

# ── SMS / Phone Verification (Twilio) ────────────────────────────────────────
# Sign up at https://www.twilio.com/
# Without credentials, OTP codes are logged to console in development.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── Search (Typesense) ────────────────────────────────────────────────────────
# Used for fast full-text hostel search. Falls back to Prisma if unavailable.
#
# Cloud (recommended): https://cloud.typesense.org/
#   TYPESENSE_HOST="xyz.typesense.com"
#   TYPESENSE_PORT="443"
#   TYPESENSE_PROTOCOL="https"
#
# Self-hosted (Docker):
#   docker run -p 8108:8108 typesense/typesense:27.1 --data-dir=/data --api-key=xyz
#   TYPESENSE_HOST="localhost"
#   TYPESENSE_PORT="8108"
#   TYPESENSE_PROTOCOL="http"
#
# After configuring, initialise the collection:
#   npx tsx scripts/setup-typesense.ts
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY=""

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Required for scheduled tasks (cancel-abandoned-payments, check-price-alerts,
# mark-completed-stays). Without these all cron endpoints return 401.
#
# CRON_SECRET: shared secret between Vercel/Upstash and your cron endpoints.
#   Generate with: openssl rand -base64 32
#   Set the SAME value in your Vercel project environment variables.
#
# QSTASH_CURRENT_SIGNING_KEY: optional extra verification of QStash payloads.
#   Get from: https://console.upstash.com/qstash → your project → signing keys
CRON_SECRET="generate-with-openssl-rand-base64-32"
QSTASH_CURRENT_SIGNING_KEY=""

# ── Scripts ───────────────────────────────────────────────────────────────────
# Used by scripts/ utilities run outside Next.js (not by the app itself).
# These are NOT the same as NEXT_PUBLIC_APP_URL.
#
# APP_URL: base URL passed to scripts/check-price-alerts.ts and
#          scripts/schedule-cron-jobs.ts when building hostel URLs in emails
#          and registering cron endpoints with Upstash.
#
# QSTASH_TOKEN: Upstash QStash API token — required by scripts/schedule-cron-jobs.ts
#               to register/update cron schedules programmatically.
#               Get from: https://console.upstash.com/qstash → API Keys
APP_URL="https://hostello.pk"
QSTASH_TOKEN=""

# ── Database Seeding ──────────────────────────────────────────────────────────
# Required when running: npm run db:seed
#
# ⚠️  NEVER run db:seed against a production database.
#     Seeding creates test accounts and sample data for local development only.
#
# Password requirements: min 8 characters, 1 uppercase letter, 1 number.
# SEED_ADMIN_EMAIL is the email address of the admin account created by the seed.
SEED_ADMIN_EMAIL="admin@hostello.pk"
SEED_ADMIN_PASSWORD=""
SEED_OWNER_PASSWORD=""
SEED_STUDENT_PASSWORD=""

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL — used by the browser for absolute links, Open Graph, etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
