# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/hostello?sslmode=require"

# Auth (NextAuth v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Cloudflare R2 Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="hostello-uploads"
R2_PUBLIC_URL=""

# Upstash Redis (rate limiting, caching, queues)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Payment Gateways ──────────────────────────────────────────────────────────

# Safepay (card payments)
# Dashboard: https://getsafepay.com/dashboard
SAFEPAY_SECRET=""
SAFEPAY_WEBHOOK_SECRET=""
NEXT_PUBLIC_SAFEPAY_ENV="sandbox"   # "sandbox" | "production"

# JazzCash (mobile wallet)
# Dashboard: https://sandbox.jazzcash.com.pk/MerchantPortal
# Production: https://payments.jazzcash.com.pk/MerchantPortal
JAZZCASH_MERCHANT_ID=""
JAZZCASH_PASSWORD=""
JAZZCASH_INTEGRITY_SALT=""
JAZZCASH_ENV="sandbox"              # "sandbox" | "production"

# EasyPaisa (mobile wallet)
# Dashboard: https://easypaisasandbox.pk/MerchantPortal
# Production: https://easypaisa.com.pk/MerchantPortal
EASYPAISA_STORE_ID=""
EASYPAISA_HASH_KEY=""               # 16-character AES key from the portal
EASYPAISA_ENV="sandbox"            # "sandbox" | "production"

# ─────────────────────────────────────────────────────────────────────────────

# Resend (email)
RESEND_API_KEY=""
EMAIL_FROM="HostelLo <noreply@hostello.pk>"
SUPPORT_EMAIL="support@hostello.pk"

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Typesense (search)
TYPESENSE_HOST=""
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
