build*.txt
build-*.log
build-*.txt

# Covers logs nested anywhere: logs/ci/build.log, packages/app/logs/build.log
logs/
**/logs/*.log
**/build/*.log

# Catch-all for any .log file dropped at root (npm, yarn, pip, etc.)
*.log

