# Sentry Configuration
# Get your DSN from https://sentry.io/settings/[org]/projects/[project]/keys/dsn/

# Required for both client and server (but for different purposes)
# NEXT_PUBLIC_SENTRY_DSN - Client-side error tracking (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Server-side configuration
SENTRY_DSN=https://examplePrivateKey@o0.ingest.sentry.io/0

# Optional: For automatic release tracking and source map uploads
SENTRY_ORG=your-org-name
SENTRY_PROJECT=your-project-name
SENTRY_AUTH_TOKEN=your-auth-token

# Set the environment
NODE_ENV=production
